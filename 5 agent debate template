import asyncio
from openai import OpenAI

# -----------------------------
# OLLAMA CLIENT (LOCAL)
# -----------------------------
client = OpenAI(
    base_url="http://localhost:11434/v1",
    api_key="ollama"
)

MODEL = "llama3"

# -----------------------------
# AGENTS
# -----------------------------
AGENTS = {
    "planner": "You design a clear structured solution.",
    "architect": "You focus on system design, scalability, and structure.",
    "security": "You analyze security risks, vulnerabilities, and mitigations.",
    "critic": "You find flaws, missing pieces, and logic issues.",
    "executor": "You convert designs into implementation steps."
}

# -----------------------------
# LLM CALL
# -----------------------------
def call_agent(role, system_prompt, context):
    resp = client.chat.completions.create(
        model=MODEL,
        messages=[
            {"role": "system", "content": system_prompt},
            {"role": "user", "content": context}
        ],
        temperature=0.6
    )
    return resp.choices[0].message.content


async def run_agent(role, system_prompt, context):
    loop = asyncio.get_event_loop()
    return await loop.run_in_executor(None, call_agent, role, system_prompt, context)

# -----------------------------
# DEBATE GRAPH VISUALIZER
# -----------------------------
def print_debate_graph(round_num, outputs):
    security = outputs["security"].lower()
    critic = outputs["critic"].lower()

    bad_signals = ["issue", "problem", "risk", "vulnerability", "missing", "concern"]

    security_flags = sum(word in security for word in bad_signals)
    critic_flags = sum(word in critic for word in bad_signals)

    print("\n" + "═" * 70)
    print(f"        🔁 ROUND {round_num} DEBATE GRAPH")
    print("═" * 70)

    print("\nPlanner     ───┐")
    print("Architect   ───┼──▶  🧠 SYSTEM MERGE")
    print("Security    ───┼")
    print("Critic      ───┤")
    print("Executor    ───┘")

    print("\n────────────────────────────────────────────")

    print(f"🔥 Security Flags: {security_flags}")
    print(f"⚠️ Critic Flags:   {critic_flags}")

    total = security_flags + critic_flags

    if total == 0:
        print("✅ Stable state (converged-like)")
    elif total <= 2:
        print("🟡 Refining state (minor debate)")
    else:
        print("🔴 High conflict state (active disagreement)")

    print("────────────────────────────────────────────\n")

# -----------------------------
# CONVERGENCE CHECK
# -----------------------------
def check_convergence(state):
    security = state["security"].lower()
    critic = state["critic"].lower()

    bad_signals = ["issue", "problem", "risk", "vulnerability", "missing", "concern"]

    security_score = sum(word in security for word in bad_signals)
    critic_score = sum(word in critic for word in bad_signals)

    return (security_score + critic_score) == 0

# -----------------------------
# MAIN LOOP
# -----------------------------
async def main():
    topic = "Design a modern IT helpdesk ticket system."

    state = {
        "topic": topic,
        "planner": "",
        "architect": "",
        "security": "",
        "critic": "",
        "executor": ""
    }

    max_rounds = 5

    for round_num in range(max_rounds):
        print(f"\n\n================ ROUND {round_num + 1} ================\n")

        # Run all agents concurrently
        results = await asyncio.gather(
            run_agent("planner", AGENTS["planner"], str(state)),
            run_agent("architect", AGENTS["architect"], str(state)),
            run_agent("security", AGENTS["security"], str(state)),
            run_agent("critic", AGENTS["critic"], str(state)),
            run_agent("executor", AGENTS["executor"], str(state)),
        )

        outputs = {
            "planner": results[0],
            "architect": results[1],
            "security": results[2],
            "critic": results[3],
            "executor": results[4],
        }

        # LIVE DEBATE GRAPH
        print_debate_graph(round_num + 1, outputs)

        # Print agent outputs
        for k, v in outputs.items():
            print(f"\n--- {k.upper()} ---\n{v}\n")

        # Update shared state
        state.update(outputs)

        # Check convergence
        if check_convergence(state):
            print("\n\n✅ CONVERGENCE REACHED\n")
            break

    # Final summary
    print("\n\n🏁 FINAL STATE SNAPSHOT\n")
    for k, v in state.items():
        print(f"\n{k.upper()}:\n{v}\n")


if __name__ == "__main__":
    asyncio.run(main())
